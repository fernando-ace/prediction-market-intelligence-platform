generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Market {
  id               String              @id @default(cuid())
  platform         String
  externalMarketId String
  ticker           String
  eventTicker      String?
  title            String
  description      String?
  resolutionRules  String?
  category         String?
  status           String
  closeTime        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  orderbookSnapshots OrderbookSnapshot[]
  signals            Signal[]
  paperTrades        PaperTrade[]
  paperPositions     PaperPosition[]
  relatedGroups      RelatedMarketGroupMarket[]
  groupPaperFills    PaperFill[]

  @@unique([platform, externalMarketId])
  @@index([platform, status])
  @@index([platform, eventTicker])
  @@index([closeTime])
}

model RelatedMarketGroup {
  id                     String   @id @default(cuid())
  groupKey               String
  platform               String
  eventTicker            String?
  marketCount            Int
  marketTickers          Json
  marketTitles           Json
  closeTimes             Json
  closeTimeSpreadSeconds Int?
  groupingReason         String
  confidenceScore        Decimal  @db.Decimal(10, 6)
  eligible               Boolean
  eligibilityReason      String
  warnings               Json?
  latestSnapshotTime     DateTime?
  totalYesAskCost        Decimal? @db.Decimal(10, 6)
  grossEdge              Decimal? @db.Decimal(10, 6)
  estimatedFees          Decimal? @db.Decimal(10, 6)
  netEdge                Decimal? @db.Decimal(10, 6)
  validationFlags        Json?
  rawJson                Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  markets     RelatedMarketGroupMarket[]
  signals     Signal[]
  paperTrades PaperTrade[]

  @@unique([platform, groupKey])
  @@index([platform, eligible])
  @@index([eventTicker])
}

model RelatedMarketGroupMarket {
  id             String @id @default(cuid())
  relatedGroupId String
  marketId       String
  platform       String
  marketTicker   String
  title          String?
  yesAsk         Decimal? @db.Decimal(10, 6)
  yesBid         Decimal? @db.Decimal(10, 6)
  noAsk          Decimal? @db.Decimal(10, 6)
  noBid          Decimal? @db.Decimal(10, 6)
  closeTime      DateTime?
  sortOrder      Int

  relatedGroup RelatedMarketGroup @relation(fields: [relatedGroupId], references: [id], onDelete: Cascade)
  market       Market             @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([relatedGroupId, marketId])
  @@index([marketId])
  @@index([platform, marketTicker])
}

model OrderbookSnapshot {
  id          String   @id @default(cuid())
  marketId    String
  platform    String
  capturedAt  DateTime
  bestYesBid  Decimal? @db.Decimal(10, 6)
  bestYesAsk  Decimal? @db.Decimal(10, 6)
  bestNoBid   Decimal? @db.Decimal(10, 6)
  bestNoAsk   Decimal? @db.Decimal(10, 6)
  spread      Decimal? @db.Decimal(10, 6)
  validationFlags Json?
  liquidityUsedByDetector Decimal? @db.Decimal(18, 6)
  parseWarnings String?
  rawJson     Json

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, capturedAt])
  @@index([platform, capturedAt])
}

model Signal {
  id              String   @id @default(cuid())
  marketId        String
  relatedGroupId  String?
  platform        String
  strategy        String
  detectedAt      DateTime
  grossEdge       Decimal? @db.Decimal(10, 6)
  estimatedFees   Decimal  @db.Decimal(10, 6)
  netEdge         Decimal? @db.Decimal(10, 6)
  maxContracts    Decimal  @db.Decimal(18, 6)
  confidenceScore Decimal  @db.Decimal(10, 6)
  liquidityScore  Decimal  @db.Decimal(18, 6)
  status          String
  reason          String
  rawJson         Json

  market       Market              @relation(fields: [marketId], references: [id], onDelete: Cascade)
  relatedGroup RelatedMarketGroup? @relation(fields: [relatedGroupId], references: [id], onDelete: SetNull)
  paperTrades  PaperTrade[]

  @@index([marketId, detectedAt])
  @@index([relatedGroupId, detectedAt])
  @@index([platform, strategy, status])
}

model PaperTrade {
  id                     String   @id @default(cuid())
  signalId               String
  marketId               String
  relatedGroupId         String?
  platform               String
  strategy               String
  createdAt              DateTime @default(now())
  executionDelaySeconds  Int
  targetExecutionTime     DateTime?
  actualSnapshotExecutionTime DateTime?
  status                 String
  expectedNetEdge        Decimal? @db.Decimal(18, 6)
  realizedNetEdge        Decimal? @db.Decimal(18, 6)
  yesAskAtSignal         Decimal? @db.Decimal(10, 6)
  noAskAtSignal          Decimal? @db.Decimal(10, 6)
  yesFillAveragePrice    Decimal? @db.Decimal(10, 6)
  noFillAveragePrice     Decimal? @db.Decimal(10, 6)
  yesContractsFilled     Decimal? @db.Decimal(18, 6)
  noContractsFilled      Decimal? @db.Decimal(18, 6)
  pairedContracts        Decimal? @db.Decimal(18, 6)
  unpairedContractsDiscarded Decimal? @db.Decimal(18, 6)
  feeEstimate            Decimal? @db.Decimal(18, 6)
  failureReason          String?
  notes                  String?

  signal       Signal              @relation(fields: [signalId], references: [id], onDelete: Cascade)
  market       Market              @relation(fields: [marketId], references: [id], onDelete: Cascade)
  relatedGroup RelatedMarketGroup? @relation(fields: [relatedGroupId], references: [id], onDelete: SetNull)
  fills        PaperFill[]

  @@index([signalId])
  @@index([marketId, createdAt])
  @@index([relatedGroupId, createdAt])
  @@index([status])
}

model PaperFill {
  id           String   @id @default(cuid())
  paperTradeId String
  marketId     String?
  marketTicker String?
  legRole      String?
  side         String
  outcome      String
  price        Decimal  @db.Decimal(10, 6)
  contracts    Decimal  @db.Decimal(18, 6)
  fees         Decimal  @db.Decimal(18, 6)
  filledAt     DateTime

  paperTrade PaperTrade @relation(fields: [paperTradeId], references: [id], onDelete: Cascade)
  market     Market?    @relation(fields: [marketId], references: [id], onDelete: SetNull)

  @@index([paperTradeId])
  @@index([marketId])
  @@index([filledAt])
}

model PaperPosition {
  id              String   @id @default(cuid())
  marketId        String
  platform        String
  outcome         String
  contracts       Decimal  @db.Decimal(18, 6)
  averagePrice    Decimal  @db.Decimal(10, 6)
  estimatedFees   Decimal  @db.Decimal(18, 6)
  simulatedPnl    Decimal? @db.Decimal(18, 6)
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, outcome])
  @@index([status])
}

model PortfolioSnapshot {
  id                String   @id @default(cuid())
  capturedAt        DateTime @default(now())
  cashBalance       Decimal  @db.Decimal(18, 6)
  totalPositionCost Decimal  @db.Decimal(18, 6)
  realizedPnl       Decimal  @db.Decimal(18, 6)
  unrealizedPnl     Decimal  @db.Decimal(18, 6)
  simulatedPnl      Decimal  @db.Decimal(18, 6)
  rawJson           Json

  @@index([capturedAt])
}

model RunLog {
  id                 String    @id @default(cuid())
  runType            String
  startedAt          DateTime  @default(now())
  finishedAt         DateTime?
  status             String
  marketsFetched     Int       @default(0)
  snapshotsStored    Int       @default(0)
  signalsCreated     Int       @default(0)
  paperTradesCreated Int       @default(0)
  message            String?
  error              String?
  rawJson            Json?

  @@index([runType, startedAt])
  @@index([status])
}
